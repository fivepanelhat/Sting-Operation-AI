# Sting-Operation-AI Environment Configuration
# Copy this file to .env and configure.

# API Key for Roboflow Hosted Inference (optional)
ROBOFLOW_API_KEY=your_roboflow_private_api_key_here

# STING OPERATION AI: DO NOT PUT REAL VALUES HERE
# Edge AI Configuration
RTSP_CAMERA_STREAM=rtsp://user:pass@192.168.1.x:554/stream
AI_CONFIDENCE_THRESHOLD=0.85
ALERT_MQTT_TOPIC=sting/alerts
LOCAL_INFERENCE_PORT=5000

